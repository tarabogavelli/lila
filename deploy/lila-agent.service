[Unit]
Description=Lila LiveKit Agent Worker
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/lila/backend
EnvironmentFile=/home/ec2-user/lila/backend/.env
ExecStart=/home/ec2-user/lila/backend/.venv/bin/python -m agent.agent start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
